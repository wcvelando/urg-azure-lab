# terraform/backend.tf.example
# Copiar como backend.tf y completar con los valores del setup-backend.sh
# backend.tf está en .gitignore: NUNCA commitear con valores reales
terraform {
  backend "azurerm" {
    resource_group_name  = "rg-terraform-state"
    storage_account_name = "COMPLETAR_CON_TU_STORAGE_ACCOUNT"
    container_name       = "tfstate"
    key                  = "lab-devsecops-azure.tfstate"
  }
}
